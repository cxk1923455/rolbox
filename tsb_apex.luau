-- рҹ§  AI жҲҳж–—еӨ§и„‘
--==================================================================
task.spawn(function()
    local blockHeld=false
    local lastM1,lastSkill,lastQ,lastUlt=0,0,0,0
    local parryUntil,dodgeUntil=0,0
    local enemyM1=setmetatable({},{__mode="k"}); local enemySk=setmetatable({},{__mode="k"})
    local skillRot=1; local kaIndex=0

    local function setBlock(on) if on and not blockHeld then kd(Enum.KeyCode.F); blockHeld=true elseif (not on) and blockHeld then ku(Enum.KeyCode.F); blockHeld=false end end
    local function faceTo(hrp,tt) local aim=tt.Position + (State.PredictAim and tt.AssemblyLinearVelocity*State.PredictLead or Vector3.zero); hrp.CFrame=CFrame.lookAt(hrp.Position,Vector3.new(aim.X,hrp.Position.Y,aim.Z)) end

    while ScreenGui.Parent do
        task.wait(0.03)
        local char,h,hrp=getChar()
        local manual=State.AutoCombo or State.AutoBlock
        local active=State.AIBrain or manual
        if not active or not(char and hrp and h and h.Health>0) then
            setBlock(false); HUD.state=State.AIBrain and "зӯүеҫ…йҮҚз”ҹ" or "еҫ…жңә"; HUD.action="вҖ”"; HUD.target="ж— "
        else
            local now=os.clock()
            local tgt,nearCount=pickTarget(hrp)
            local skills=readSkills()
            local myHP=h.Health/h.MaxHealth*100; HUD.hp=math.floor(myHP)
            local target=tgt and tgt.char; local thrp=tgt and tgt.t; local th=tgt and tgt.h
            local dist=thrp and (thrp.Position-hrp.Position).Magnitude or 999

            -- йў„еҲӨдҝЎеҸ·
            local rec
            if target then rec=track(target)
                if dist<=34 then
                    local m1t=target:GetAttribute("LastM1Fire"); if m1t and enemyM1[target]~=m1t then enemyM1[target]=m1t; parryUntil=now+0.42 end
                    local skt=target:GetAttribute("LastSkill"); if skt and enemySk[target]~=skt then enemySk[target]=skt; dodgeUntil=now+0.5 end
                end
            end
            local reactBlock=State.ReactiveParry and now<parryUntil
            local reactDodge=State.SkillDodge and now<dodgeUntil
            if target and thrp and State.AutoFace then faceTo(hrp,thrp) end

            if State.AIBrain then
                HUD.target=target and tgt.name or "ж— "; HUD.dist=math.floor(dist); HUD.combo=char:GetAttribute("Combo") or 0
                HUD.enemyChar=target and (target:GetAttribute("Character") or "?") or "вҖ”"
                HUD.archetype=(target and rec) and archetype(target,rec) or "вҖ”"
                HUD.threat=(target and dist<=16) and "й«ҳ" or (target and dist<=45 and "дёӯ" or "дҪҺ")

                -- 1) йҖғз”ҹ(жңӘејҖ KillAura ж—¶жүҚйҖғ)
                if State.AutoEscape and myHP<=State.EscapeHP and target and not State.KillAura then
                    HUD.state="рҹӣҹйҖғз”ҹ"; setBlock(true)
                    if State.AutoApproach then h:MoveTo(hrp.Position+(hrp.Position-thrp.Position).Unit*45) end
                    local up=State.UseSkills and pickRole(skills,"launcher"); if up and up.ready and dist<=12 then setBlock(false); useSkill(up.slot); HUD.action="жҢ‘з©әжү“ж–ӯ" end

                -- 2) вҳ пёҸ Kill Aura:зһ¬з§»иҪ®жөҒй”Ғе®ҡе…Ёеңә,йҖҗдёӘиҝһжү“(жңҖжҺҘиҝ‘е…ЁеұҸ)
                elseif State.KillAura then
                    local inR={}
                    for _,e in ipairs(candidates()) do if (e.t.Position-hrp.Position).Magnitude<=State.KillAuraRange then inR[#inR+1]=e end end
                    if #inR>0 then
                        HUD.state="вҳ пёҸKillAura"; HUD.action=#inR.."ж•ҢВ·иҪ®иҪ¬"; setBlock(false)
                        local ready=char:GetAttribute("M1Ready")
                        if (ready==nil or ready==true) and now-lastM1>=0.13 then
                            kaIndex=(kaIndex % #inR)+1; local e=inR[kaIndex]
                            hrp.CFrame=e.t.CFrame*CFrame.new(0,0,-2.6); faceTo(hrp,e.t); task.wait(0.02)
                            if e.char:GetAttribute("Blocking") and State.QGrab then useQ() else m1() end
                            lastM1=now
                            if State.UseSkills and now-lastSkill>=0.55 then local sk=pickRole(skills,"combo") or pickRole(skills,"launcher"); if sk and sk.ready then useSkill(sk.slot); lastSkill=now end end
                        end
                    else HUD.state="вҳ пёҸKillAuraВ·жҗң"; HUD.action="еҶІеҗ‘жңҖиҝ‘"; if target and thrp then hrp.CFrame=thrp.CFrame*CFrame.new(0,0,-3); faceTo(hrp,thrp) end end

                -- 3) 1vеӨҡйЈҺзӯқ(й»ҳи®Өе…і,дҝқе®ҲзҺ©е®¶еҸҜејҖ)
                elseif State.KiteMultiple and nearCount>=2 then
                    HUD.state="рҹҺҜйЈҺзӯқ(иў«еӣҙ)"; setBlock(true); HUD.action="жӢүејҖ+иҝңзЁӢ"
                    if State.AutoApproach and target then h:MoveTo(hrp.Position+(hrp.Position-thrp.Position).Unit*30) end
                    local rg=State.UseSkills and pickRole(skills,"ranged"); if rg and rg.ready and target then setBlock(false); faceTo(hrp,thrp); useSkill(rg.slot); HUD.action="иҝңзЁӢ:"..rg.name end

                -- 4) й—ӘйҒҝжҠҖиғҪ(еҸҜиғҪз ҙйҳІ)
                elseif reactDodge and target and thrp then
                    HUD.state="рҹҢҖй—ӘйҒҝжҠҖиғҪ"; setBlock(true)
                    local side=(thrp.Position-hrp.Position).Unit:Cross(Vector3.new(0,1,0)); h:MoveTo(hrp.Position+side*14); HUD.action="дҫ§з§»и§„йҒҝ"

                -- 5) еҸҚеә”ж јжҢЎ
                elseif reactBlock then setBlock(true); HUD.state="вҡЎе®ҢзҫҺж јжҢЎ"; HUD.action="Block"

                -- 6) иҫ“еҮә/жӢҶзӣҫ
                elseif target and thrp and dist<=State.ComboReach then
                    setBlock(false)
                    if State.HitboxTP then hrp.CFrame=CFrame.lookAt(thrp.Position-(thrp.Position-hrp.Position).Unit*2.5,Vector3.new(thrp.Position.X,hrp.Position.Y,thrp.Position.Z)) end
                    if target:GetAttribute("Blocking") then
                        -- еҜ№йқўж јжҢЎ вҶ’ Q жҠ“з©ҝзӣҫ(ж ёеҝғе…ӢеҲ¶)/з ҙйҳІжҠҖиғҪ
                        HUD.state="рҹӨјжӢҶзӣҫ"
                        if State.QGrab and now-lastQ>=1.4 then faceTo(hrp,thrp); useQ(); lastQ=now; HUD.action="QжҠ“еҸ–з©ҝзӣҫ"
                        else local bb=State.UseSkills and pickRole(skills,"blockbreak"); if bb and bb.ready then useSkill(bb.slot); HUD.action="з ҙйҳІ:"..bb.name; lastSkill=now else m1(); HUD.action="M1з ҙзӣҫ" end end
                    else
                        HUD.state="вҡ”пёҸиҝһжӢӣиҫ“еҮә"
                        local myCombo=char:GetAttribute("Combo") or 0
                        local ready=char:GetAttribute("M1Ready")
                        local m1Gap=math.clamp(0.42-State.Aggression*0.012,0.24,0.4)
                        if (ready==nil or ready==true) and not char:GetAttribute("Blocking") and now-lastM1>=m1Gap then m1(); lastM1=now; HUD.action="M1" end
                        -- иҝһжӢӣзӮ№:comboж»ЎжҺҘжҠҖиғҪ(жҢ‘з©әвҶ’иҝһеҮ»вҶ’з ҙйҳІ иҪ®иҪ¬,еҶ·еҚҙж„ҹзҹҘ)
                        local skillGap=math.clamp(1.1-State.Aggression*0.06,0.5,1.1)
                        if State.UseSkills and now-lastSkill>=skillGap and myCombo>=3 then
                            local seq={}
                            if State.AutoLauncher then seq[#seq+1]=pickRole(skills,"launcher") end
                            seq[#seq+1]=pickRole(skills,"combo"); seq[#seq+1]=pickRole(skills,"blockbreak")
                            local fired=false
                            for off=0,#seq-1 do local idx=((skillRot-1+off)%math.max(#seq,1))+1; local sk=seq[idx]
                                if sk and sk.ready then useSkill(sk.slot); HUD.action="жҠҖиғҪ:"..sk.name; lastSkill=now; skillRot=idx+1; fired=true; break end end
                        end
                    end
                    -- еӨ§жӢӣ:еҜ№йқўж®ӢиЎҖ/жҲ‘ж–№иҝһжӢӣдёӯ
                    if State.AutoUlt and now-lastUlt>=2 then local ult=pickRole(skills,"ult"); if ult and ult.ready and th and th.Health/th.MaxHealth<0.5 then useSkill(ult.slot); HUD.action="рҹ’Ҙ"..ult.name; lastUlt=now end end

                -- 7) иҝҪеҮ»(жҝҖиҝӣ:TPй”Ғиә«иҙҙи„ё / QеҶІеҲә / и·‘,з»қдёҚеҺҹең°йҳІеҫЎ)
                elseif target and thrp then
                    HUD.state="рҹҸғиҝҪеҮ»"; setBlock(false)
                    if State.TPChase then
                        hrp.CFrame=thrp.CFrame*CFrame.new(0,0,(State.TPBehind and 2.6 or -2.6)); faceTo(hrp,thrp); HUD.action="рҹ”’TPй”Ғиә«"
                    elseif State.DashClose and dist>18 and now-lastQ>=1.1 then faceTo(hrp,thrp); useQ(); lastQ=now; HUD.action="QеҶІеҲә"
                    elseif State.AutoApproach then h:MoveTo(thrp.Position); HUD.action="иҝҪеҮ»" end
                else HUD.state="рҹ”Қзҙўж•Ң"; HUD.action="вҖ”"; setBlock(false) end
            else
                -- жүӢеҠЁжЁЎејҸ
                if reactBlock then setBlock(true); HUD.state="вҡЎеҸҚеә”ж јжҢЎ"
                elseif State.AutoCombo and target and thrp and dist<=State.ComboReach then setBlock(false)
                    local ready=char:GetAttribute("M1Ready"); if (ready==nil or ready==true) and not char:GetAttribute("Blocking") and now-lastM1>=0.3 then m1(); lastM1=now end; HUD.state="вҡ”пёҸиҝһжӢӣ"
                elseif target and thrp then if State.AutoApproach then h:MoveTo(thrp.Position) end; setBlock(State.AutoBlock); HUD.state=State.AutoApproach and "рҹҸғжҺҘиҝ‘" or "зҙўж•Ң"
                else setBlock(State.AutoBlock); HUD.state=State.AutoBlock and "рҹӣЎпёҸеҫ…е‘Ҫ" or "зҙўж•Ң" end
                HUD.target=target and tgt.name or "ж— "; HUD.dist=math.floor(dist); HUD.combo=char:GetAttribute("Combo") or 0
            end
        end
    end
    setBlock(false)
end)

